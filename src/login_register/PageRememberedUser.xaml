<Page x:Class="MarkIt.login_register.PageRememberedUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MarkIt.login_register"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageRememberedUser">

    <Grid>
        <StackPanel Background="#FF1F4572">
            <Border CornerRadius="20" Background="#FF01021C" Width="400" Margin="0,15,0,0">
                <StackPanel Orientation="Vertical" Width="400">
                    <Label Content="SELECT USER" Margin="0,8,0,0" HorizontalContentAlignment="Center" Foreground="White" FontFamily="Leelawadee UI" FontSize="35" FontWeight="Bold"/>
                    <Label Content="Choose an account to continue" HorizontalContentAlignment="Center" Foreground="Gray" FontFamily="Leelawadee UI" FontSize="13" Margin="0,-4,0,10"/>
                    <StackPanel x:Name="StackPanelUsers" Margin="30,0,30,20" Orientation="Vertical">
                        
                    </StackPanel>
                    <Button x:Name="ButtonOtherUser" Click="ButtonOtherUser_Click" Cursor="Hand" Content="Use another account" Width="200" Height="35" FontSize="14" Margin="0,0,0,20" FontFamily="Leelawadee UI"/>
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" Width="335">
                <Button Margin="0,20,0,0" Content="Register instead" x:Name="ButtonRegister" Width="160" Click="ButtonRegister_Click" Cursor="Hand" FontFamily="Leelawadee UI" FontSize="14" HorizontalContentAlignment="Center"/>
                <Button Margin="15,20,0,0" Content="Continue as guest" x:Name="ButtonGuest" Width="160" Cursor="Hand" FontFamily="Leelawadee UI" FontSize="14" HorizontalContentAlignment="Center" Click="ButtonGuest_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
