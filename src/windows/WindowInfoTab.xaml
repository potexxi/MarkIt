<Window x:Class="MarkIt.windows.WindowInfoTab"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt.windows"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        mc:Ignorable="d"
        Title="Infos" Height="450" Width="800" ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="LabelForeground" Color="Black"/>

        <Style TargetType="Label">
            <Setter Property="Foreground"
                Value="{DynamicResource LabelForeground}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LabelForeground}"></Setter>
        </Style>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource LabelForeground}"></Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10,0,0,0">
        <Rectangle Margin="-10,0,0,0" x:Name="Background" Width="800" Height="450"/>
        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <!--Description-->
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <Label FontWeight="Bold" FontSize="30" Content="About MarkIt"/>
                        <Label FontSize="14" Content="MarkIt is a Markdown editor developed as a school project." Margin="0,-10,0,0"/>
                        <Label FontSize="14" Content="The application allows users to create, edit, and organize Markdown files" Margin="0,-10,0,0"/>
                        <Label FontSize="14" Content="in a modern and clean user interface." Margin="0,-10,0,0"/>
                    </StackPanel>
                    <Image Margin="120,0,0,0" Source="/images/markit-logo.png" Height="120"></Image>
                </StackPanel>
                <Separator/>
                <!--Technologies-->
                <Label FontWeight="Bold" Content="Technologies Used" FontSize="20"/>
                <Label FontSize="14" Content="• WPF" Margin="20,-8,0,0"/>
                <Label FontSize="14" Content="• C#" Margin="20,-8,0,0"/>
                <Label FontSize="14" Content="• Supabase (Backend)" Margin="20,-8,0,0"/>
                <Label FontSize="14" Content="• Markdown" Margin="20,-8,0,0"/>
                <Separator/>
                <!--Project Informations-->
                <Label FontWeight="Bold" Content="Project Information" FontSize="20"/>
                <StackPanel Orientation="Horizontal">
                    <Label FontSize="14" Content="Project:" FontWeight="Bold" Margin="20,-8,0,0"/>
                    <Label FontSize="14" Content="MarkIt" Margin="-3,-8,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label FontSize="14" Content="Version:" FontWeight="Bold" Margin="20,-8,0,0"/>
                    <Label FontSize="14" Content="0.1.0" Margin="-3,-8,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label FontSize="14" Content="Developer:" FontWeight="Bold" Margin="20,-8,0,0"/>
                    <TextBlock FontSize="14" Margin="0,-3,0,0">
                        <Hyperlink NavigateUri="https://github.com/potexxi" RequestNavigate="Hyperlink_RequestNavigate">potexxi</Hyperlink>
                    </TextBlock>
                    <TextBlock FontSize="14" Margin="10,-3,0,0">
                        <Hyperlink NavigateUri="https://github.com/K-Debbabi" RequestNavigate="Hyperlink_RequestNavigate">K-Debbabi</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label FontSize="14" Content="Type:" FontWeight="Bold" Margin="20,-8,0,0"/>
                    <Label FontSize="14" Content="school project" Margin="-3,-8,0,0"/>
                </StackPanel>
                <Separator/>
                <!--Copyright-->
                <Label FontWeight="Bold" Content="Copyright" FontSize="20"/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="© 2026 potexxi &amp; K-Debbabi. All rights reserved."/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="This project was created for educational and demonstration purposes only."/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="Copying, modifying, or redistributing the source code is not permitted without"/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="permission from the developer"/>
                <Separator/>
                <!--Disclaimer-->
                <Label FontWeight="Bold" Content="Disclaimer" FontSize="20"/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="This software is provided “as is” without any warranty."/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="The developer is not responsible for any damage, data loss, or compatibility"/>
                <Label FontSize="14" Margin="0,-5,0,0" Content="issues caused by the use of this application."/>
                <Separator/>
                <!--End-->
                <TextBlock Margin="5,10,0,0" FontSize="18"> View the whole project on GitHub:
                        <Hyperlink NavigateUri="https://github.com/potexxi/MarkIt" RequestNavigate="Hyperlink_RequestNavigate">https://github.com/potexxi/MarkIt</Hyperlink>
                </TextBlock>
                <uc:CustomButton Margin="0,20,10,0" Cursor="Hand" PreviewMouseDown="CustomButton_PreviewMouseDown" CustomContent="Back" Width="100" Height="50"/>
                <Rectangle Height="50"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
