<Window x:Class="MarkIt.windows.WindowRename"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt.windows"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        mc:Ignorable="d" KeyDown="Window_KeyDown"
        Title="Rename" Height="200" Width="500">
    <Grid Background="#FFE5E5E5">
        <StackPanel Margin="20,20,20,80">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Label x:Name="LBL_Name" Content="New Name:" FontSize="20" FontWeight="Bold" Width="160"/>
                <uc:CustomTextBox x:Name="CT_Name" Width="270" Height="33" MaxCharLength="100"/>
            </StackPanel>

            <!-- Validation error message -->
            <TextBlock x:Name="TBL_Error" Text="" Foreground="Red" FontSize="13"
                       Margin="162,4,0,0" Visibility="Collapsed"/>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" Orientation="Horizontal">
            <uc:CustomButton Width="100" Height="50" Margin="0,0,10,0" CustomContent="Save" PreviewMouseDown="CustomButton_PreviewMouseDown_1"/>
            <uc:CustomButton Width="100" Height="50" CustomContent="Back" PreviewMouseDown="CustomButton_PreviewMouseDown"/>
        </StackPanel>
        <Grid Visibility="Hidden" x:Name="LoadingScreen">
            <Rectangle Fill="#FF1F4572" Opacity="0.5"></Rectangle>
            <Image Width="100" Visibility="Visible" Height="100" gif:ImageBehavior.AnimatedSource="/images/loading-animation.gif"></Image>
        </Grid>
    </Grid>
</Window>
