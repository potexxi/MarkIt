<Window x:Class="MarkIt.windows.WindowCreateAssistent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt.windows"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="Create Assistant" Height="300" Width="500">
    <!--ALles von Claude code, weil zu faul, das ganze UI zu machen-->
    <!--PROMPT: mache mir ein neues window fuer file create assistent, mache es sinnvoll wie die anderen windows alle-->
    <Grid Background="#FFE5E5E5">
        <StackPanel Margin="20,20,20,80">

            <!-- Location: Local / Cloud -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Label Content="Location" FontSize="20" FontWeight="Bold" Width="160"/>
                <RadioButton x:Name="RB_Local" Content="Local" FontSize="16" VerticalContentAlignment="Center" VerticalAlignment="Center"
                             Margin="0,0,20,0" IsChecked="True" Checked="RadioButton_Changed"/>
                <RadioButton x:Name="RB_Cloud" Content="Cloud" FontSize="16" VerticalContentAlignment="Center" VerticalAlignment="Center"
                             Checked="RadioButton_Changed"/>
            </StackPanel>

            <!-- Type: File / Folder -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Label Content="Type" FontSize="20" FontWeight="Bold" Width="160"/>
                <RadioButton x:Name="RB_File" Content="File" FontSize="16" VerticalContentAlignment="Center" VerticalAlignment="Center"
                             Margin="0,0,20,0" IsChecked="True" Checked="RadioButton_Changed"/>
                <RadioButton x:Name="RB_Folder" Content="Folder" FontSize="16" VerticalContentAlignment="Center" VerticalAlignment="Center"
                             Checked="RadioButton_Changed"/>
            </StackPanel>

            <!-- Name -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Label x:Name="LBL_Name" Content="File Name" FontSize="20" FontWeight="Bold" Width="160"/>
                <uc:CustomTextBox x:Name="CT_Name" Width="270" Height="33" MaxCharLength="100"/>
            </StackPanel>

            <!-- Validation error message -->
            <TextBlock x:Name="TBL_Error" Text="" Foreground="Red" FontSize="13"
                       Margin="162,4,0,0" Visibility="Collapsed"/>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" Orientation="Horizontal">
            <uc:CustomButton Width="100" Height="50" Margin="0,0,10,0" CustomContent="Create" MouseDown="Button_Create_MouseDown"/>
            <uc:CustomButton Width="100" Height="50" CustomContent="Back" MouseDown="Button_Back_MouseDown"/>
        </StackPanel>
        <Grid Visibility="Hidden" x:Name="LoadingScreen">
            <Rectangle Fill="#FF1F4572" Opacity="0.5"></Rectangle>
            <Image Width="100" Visibility="Visible" Height="100" gif:ImageBehavior.AnimatedSource="/images/loading-animation.gif"></Image>
        </Grid>
    </Grid>
</Window>
    <!--Ende-->
