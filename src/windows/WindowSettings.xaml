<Window x:Class="MarkIt.windows.WindowSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt.windows"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        mc:Ignorable="d"
        Title="Settings" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="Document">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Performance">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Desine">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Accound">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
        </TabControl>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
            <uc:SwitchSlider Width="160" Height="40"/>
        </StackPanel>
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" Orientation="Horizontal">
            <uc:CustomButton Width="100" Height="50" Margin="0,0,10,0" CustomContent="Save"/>
            <uc:CustomButton Width="100" Height="50" Margin="0,0,10,0" CustomContent="Reset"/>
        </StackPanel>
    </Grid>
</Window>
