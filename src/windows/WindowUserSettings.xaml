<Window x:Class="MarkIt.windows.WindowUserSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt.windows"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        mc:Ignorable="d"
        Title="User Settings" Height="450" Width="600" ResizeMode="NoResize">
    <Grid Background="#FFE5E5E5">
        <StackPanel>
            <Border Width="100" Height="100" CornerRadius="10">
                <Border.Clip>
                    <RectangleGeometry Rect="0,0,100,100" RadiusX="100" RadiusY="100"/>
                </Border.Clip>
                <Image Source="/images/profil-user-login.jpg" Width="150" ></Image>
            </Border>
            <Label Content="" x:Name="LabelEmail" FontWeight="Bold" FontSize="20" Margin="0,-5,0,0" HorizontalContentAlignment="Center"></Label>
            <StackPanel x:Name="StackPanelGuest"></StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                <Label x:Name="LabelPassword" Content="Change your password?" FontSize="20" FontWeight="Bold"/>
                <uc:CustomButton x:Name="ButtonPassword" PreviewMouseDown="ButtonPassword_PreviewMouseDown" CustomContent="Here" Width="120" Height="37" Margin="220,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                <Label x:Name="LabelAccount" Content="Change Account:" FontSize="20" FontWeight="Bold"/>
                <uc:CustomButton x:Name="ButtonLogout" PreviewMouseDown="ButtonLogout_PreviewMouseDown" CustomContent="Logout" Width="120" Height="37" Margin="284,0,0,0"/>
            </StackPanel>
            <uc:CustomButton CustomContent="Back" x:Name="ButtonBack" Width="220" Height="45" PreviewMouseDown="ButtonBack_PreviewMouseDown" Margin="0,50,0,0"></uc:CustomButton>
        </StackPanel>
        <Grid Visibility="Hidden" x:Name="LoadingScreen">
            <Rectangle Fill="#FF1F4572" Opacity="0.6"></Rectangle>
            <Image Width="100" Visibility="Visible" Height="100" gif:ImageBehavior.AnimatedSource="/images/loading-animation.gif"></Image>
        </Grid>
    </Grid>
</Window>
