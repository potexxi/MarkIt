<Window x:Class="MarkIt.windows.WindowColorpicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt.windows"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        xmlns:ucColors="clr-namespace:MarkIt.UserControls.usercontrolsColor"
        mc:Ignorable="d"
        Title="WindowColorpicker" Height="500" Width="370">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
            <ucColors:ColorDisplay x:Name="ColorDisplay" Width="300" Height="100"/>
            <ucColors:ColorPercentage Width="300" Height="40" Margin="0, 30" ColorRect="Black"/>
            <ucColors:ColorPercentage x:Name="r" Width="300" Height="40" Margin="5" ColorRect="Red"/>
            <ucColors:ColorPercentage x:Name="g" Width="300" Height="40" Margin="5" ColorRect="Green"/>
            <ucColors:ColorPercentage x:Name="b" Width="300" Height="40" Margin="5" ColorRect="Blue"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="30">
            <uc:CustomButton CustomContent="Apply" Width="140"/>
            <uc:CustomButton CustomContent="Back" Width="140" Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
