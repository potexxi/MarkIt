<Window x:Class="MarkIt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkIt"
        xmlns:uc="clr-namespace:MarkIt.UserControls"
        xmlns:CB_uc="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="MarkIt" Height="850" Width="1200" SizeChanged="Window_SizeChanged" MinWidth="620" MinHeight="400" Icon="/images/markit-logo.png">
    <Grid x:Name="GridMain">
        <StackPanel x:Name="StackPanelMainWindow" Orientation="Vertical">
            <DockPanel>
                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="File" Opacity="0.6">
                        <MenuItem x:Name="MenuItemNewFile" Header="New" Cursor="Hand" />
                        <MenuItem x:Name="MenuItemOpenFile" Header="Open" Cursor="Hand" />
                        <MenuItem x:Name="MenuItemSaveFile" Header="Save" Cursor="Hand" />
                        <Separator/>
                        <MenuItem x:Name="MenuItemWorkspace" Header="Open File-Workspace" Cursor="Hand" PreviewMouseDown="MenuItemWorkspace_PreviewMouseDown"/>
                    </MenuItem>
                    <MenuItem Header="Options" Opacity="0.6">
                        <MenuItem Header="Open Settings" x:Name="MenuItemGeneralSettings" PreviewMouseDown="MenuItemGeneralSettings_PreviewMouseDown" Cursor="Hand"/>
                        <MenuItem Header="Open User Settings" x:Name="MenuItemUserSettings" Cursor="Hand" PreviewMouseDown="MenuItemUserSettings_PreviewMouseDown"></MenuItem>
                        <Separator />
                        <MenuItem Header="Exit" x:Name="MenuItemExit" PreviewMouseDown="MenuItemExit_PreviewMouseDown"/>
                    </MenuItem>
                    <MenuItem Header="Info" Opacity="0.6">
                        <MenuItem Header="Credits" Cursor="Hand" x:Name="MenuItemCredits" PreviewMouseDown="MenuItemCredits_PreviewMouseDown"></MenuItem>
                        <MenuItem Header="Help" Cursor="Hand"></MenuItem>
                    </MenuItem>
                </Menu>
            </DockPanel>
            <Grid x:Name="StackPanelNavigationBar" Background="Gray" HorizontalAlignment="Stretch" Height="120">
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Orientation="Horizontal" Margin="20">
                    <uc:SettingsIcon x:Name="UC_Settings" Width="50" Height="50"/>
                    <uc:AccoundIcon x:Name="UC_AccountIcon" Width="50" Height="50"/>
                    <uc:InformationIcon x:Name="UC_Information" PreviewMouseDown="InformationIcon_PreviewMouseDown" Width="50" Height="50"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical">
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Orientation="Horizontal" Margin="7">
                            <CB_uc:CB_Bold x:Name="CB_Bold" Width="50" Height="50" Margin="0,0,0,0" MouseDown="CB_Bold_MouseDown"></CB_uc:CB_Bold>
                            <CB_uc:CB_Code x:Name="CB_Code" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Code_MouseDown"></CB_uc:CB_Code>
                            <CB_uc:CB_Italic x:Name="CB_Italic" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Italic_MouseDown"></CB_uc:CB_Italic>
                            <CB_uc:CB_StrikeThrough x:Name="CB_Striketrough" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Striketrough_MouseDown"></CB_uc:CB_StrikeThrough>
                            <CB_uc:CB_Underlined x:Name="CB_Underline" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Underline_MouseDown"></CB_uc:CB_Underlined>

                        </StackPanel>
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Orientation="Horizontal" Margin="7,0,0,0">
                            <CB_uc:CB_Subscript x:Name="CB_Subscript" Width="50" Height="50" Margin="0,0,0,0" MouseDown="CB_Subscript_MouseDown"></CB_uc:CB_Subscript>
                            <CB_uc:CB_Superscript x:Name="CB_Superscript" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Superscript_MouseDown"></CB_uc:CB_Superscript>
                            <CB_uc:CB_Quote x:Name="CB_Quote" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Quote_MouseDown"></CB_uc:CB_Quote>
                            <CB_uc:CB_Link x:Name="CB_Link" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Link_MouseDown"></CB_uc:CB_Link>
                            <CB_uc:CB_Image x:Name="CB_Image" Width="50" Height="50" Margin="10,0,0,0" MouseDown="CB_Image_MouseDown"></CB_uc:CB_Image>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Orientation="Horizontal">
                        <CB_uc:MultiSelection x:Name="MS_Headers" Width="300" Height="50" MouseDown="MS_Headers_MouseDown" Margin="0, 0, 0, 0"></CB_uc:MultiSelection>
                        <CB_uc:MultiSelection x:Name="MS_List" Width="300" Height="50" MouseDown="MS_List_MouseDown" Margin="15, 0, 0, 0"></CB_uc:MultiSelection>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid x:Name="GridWorksheet" Background="LightGray" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </StackPanel>
        <uc:FileBar Opacity="1" x:Name="filebar"></uc:FileBar>
        <Grid Visibility="Hidden" x:Name="LoadingScreen">
            <Rectangle Fill="#FF1F4572" Opacity="0.6"></Rectangle>
            <Image Width="100" Visibility="Visible" Height="100" gif:ImageBehavior.AnimatedSource="/images/loading-animation.gif"></Image>
        </Grid>
    </Grid>
</Window>
