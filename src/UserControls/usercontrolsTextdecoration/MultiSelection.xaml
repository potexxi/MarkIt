<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.MultiSelection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="200">
    <Grid VerticalAlignment="Top" HorizontalAlignment="Stretch">
        <Rectangle x:Name="Rect_BG" Fill="White" Stroke="Black" StrokeThickness="5" RadiusX="5" RadiusY="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"></Rectangle>
        <Label x:Name="Label_Selection" Content="Default Text" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"></Label>
        <Popup x:Name="DropdownPopup"
           PlacementTarget="{Binding ElementName=Rect_Hitbox}"
           Placement="Bottom"
           StaysOpen="True"
           MouseLeave="DropdownItems_MouseLeave">
            <StackPanel x:Name="Stackpannel_Items" Background="Transparent"/>
        </Popup>
        <!-- this popup Idear came from ChatGPT to make it posible for the items to go under the Stackpannel that is given-->
        <Rectangle x:Name="Rect_Hitbox" MouseEnter="Rect_Hitbox_MouseEnter" MouseLeave="Rect_Hitbox_MouseLeave" Fill="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
    </Grid>
</UserControl>
