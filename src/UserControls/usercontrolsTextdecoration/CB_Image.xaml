<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_Image"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Rectangle x:Name="el1" Stroke="Black" StrokeThickness="4" Margin="6,10,6,10" RadiusX="4" RadiusY="4"/>
        <Polyline x:Name="el2" Points="10,38, 20,25, 27,30, 33,22, 41, 38" Stroke="Black" StrokeThickness="3"></Polyline>
        <Ellipse x:Name="el3" HorizontalAlignment="Left" Height="8" Margin="11,15,0,0" Stroke="Black" StrokeThickness="2" VerticalAlignment="Top" Width="8"/>
        <Rectangle x:Name="CB_Hitbox" Fill="Transparent" MouseDown="CB_Hitbox_MouseDown" MouseEnter="CB_Hitbox_MouseEnter" MouseLeave="CB_Hitbox_MouseLeave"/>
    </Grid>
</UserControl>
