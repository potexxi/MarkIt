<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_Bold"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>

        <Ellipse x:Name="Ellipse_Bu" HorizontalAlignment="Left" Height="16" Margin="11,7,0,0" Stroke="Black" VerticalAlignment="Top" Width="23" StrokeThickness="5"/>
        <Ellipse x:Name="Ellipse_Bl" HorizontalAlignment="Left" Height="22" Margin="8,21,0,0" Stroke="Black" VerticalAlignment="Top" Width="29" StrokeThickness="5"/>
        <Rectangle x:Name="Rect_B" HorizontalAlignment="Left" Height="36" Margin="14,0,0,0" VerticalAlignment="Center" Width="7" Fill="Black"/>
        <Rectangle x:Name="Rectbackground" HorizontalAlignment="Left" Height="36" Margin="8,0,0,0" VerticalAlignment="Center" Width="6" Fill="White"/>
        <Rectangle x:Name="CB_Hitbox" Fill="Transparent" MouseDown="CB_Hitbox_MouseDown" MouseEnter="CB_Hitbox_MouseEnter" MouseLeave="CB_Hitbox_MouseLeave"/>
    </Grid>
</UserControl>
