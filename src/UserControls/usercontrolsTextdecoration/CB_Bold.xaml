<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_Bold"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="2" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>

        <Rectangle HorizontalAlignment="Left" Height="36" Margin="14,0,0,0" Stroke="Black" VerticalAlignment="Center" Width="7" Fill="Black"/>
        <Ellipse HorizontalAlignment="Left" Height="18" Margin="8,7,0,0" Stroke="Black" VerticalAlignment="Top" Width="28" StrokeThickness="5"/>
        <Ellipse HorizontalAlignment="Left" Height="23" Margin="8,20,0,0" Stroke="Black" VerticalAlignment="Top" Width="30" StrokeThickness="5"/>
        <Rectangle HorizontalAlignment="Left" Height="36" Margin="8,0,0,0" VerticalAlignment="Center" Width="6" Fill="White"/>
    </Grid>
</UserControl>
