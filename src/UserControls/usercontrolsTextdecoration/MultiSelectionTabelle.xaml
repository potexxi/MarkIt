<UserControl x:Class="MarkIt.UserControls.MultiSelectionTabelle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Rectangle x:Name="el1" HorizontalAlignment="Center" Height="80" Stroke="Black" StrokeThickness="3" RadiusX="5" RadiusY="5" VerticalAlignment="Center" Width="80"/>
        <Rectangle x:Name="el2" HorizontalAlignment="Center" Height="25" Stroke="Black" Fill="Gray" StrokeThickness="3" RadiusX="5" RadiusY="5" VerticalAlignment="Top" Width="80" Margin="0,10,0,0"/>
        <Rectangle x:Name="el3" HorizontalAlignment="Center" Height="58" Stroke="Black" StrokeThickness="3" VerticalAlignment="Top" Width="32" Margin="0,32,0,0"/>
        <Rectangle x:Name="el4" HorizontalAlignment="Center" Height="21" Stroke="Black" StrokeThickness="3" VerticalAlignment="Top" Width="80" Margin="0,50,0,0"/>
        <Rectangle x:Name="CB_Hitbox" Fill="Transparent" MouseEnter="CB_Hitbox_MouseEnter" MouseLeave="CB_Hitbox_MouseLeave"/>
        <!--ChatGPT-->
        <Popup x:Name="TablePopup"
       PlacementTarget="{Binding ElementName=CB_Hitbox}"
       Placement="Bottom"
       StaysOpen="True"
       AllowsTransparency="True">

            <Border x:Name="PopupContent"
            Background="White"
            Padding="6"
            CornerRadius="6"
            MouseLeave="Popup_MouseLeave">

                <StackPanel x:Name="SP_TableGrid"/>

            </Border>
        </Popup>
        <!--ChatGPT ende-->
    </Grid>
</UserControl>
