<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_Underlined"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Ellipse HorizontalAlignment="Center" Height="28" Stroke="Black" VerticalAlignment="Top" Width="24" StrokeThickness="7" Margin="0,8,0,0"/>
        <Rectangle Fill="White" Margin="7,6,7,28"/>
        <Rectangle HorizontalAlignment="Center" Height="7" Fill="Black" VerticalAlignment="Top" Width="30" Margin="0,36,0,0"/>
        <Rectangle HorizontalAlignment="Left" Height="14" Fill="Black" VerticalAlignment="Top" Width="7" Margin="30,8,0,0"/>
        <Rectangle HorizontalAlignment="Left" Height="14" Fill="Black" VerticalAlignment="Top" Width="7" Margin="13,8,0,0"/>
    </Grid>
</UserControl>
