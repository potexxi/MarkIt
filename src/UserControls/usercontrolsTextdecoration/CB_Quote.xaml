<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_Quote"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Ellipse x:Name="eli1" HorizontalAlignment="Left" Height="15" Margin="9,15,0,0" Fill="Black" VerticalAlignment="Top" Width="15"/>
        <Ellipse x:Name="eli2" HorizontalAlignment="Left" Height="15" Margin="26,15,0,0" Fill="Black" VerticalAlignment="Top" Width="15"/>
        <Rectangle x:Name="el1" HorizontalAlignment="Left" Height="13" Margin="17,24,0,0" Fill="Black" VerticalAlignment="Top" Width="4" RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="22.697"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <Rectangle x:Name="el2" HorizontalAlignment="Left" Height="13" Margin="34,24,0,0" Fill="Black" VerticalAlignment="Top" Width="4" RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="22.697"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <Rectangle x:Name="CB_Hitbox" Fill="Transparent" MouseDown="CB_Hitbox_MouseDown" MouseEnter="CB_Hitbox_MouseEnter" MouseLeave="CB_Hitbox_MouseLeave"/>
    </Grid>
</UserControl>
