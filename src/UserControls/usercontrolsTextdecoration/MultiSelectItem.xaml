<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.MultiSelectItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="300">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Rectangle x:Name="Rect_BG" Fill="White" Stroke="Black" StrokeThickness="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"></Rectangle>
        <Label x:Name="Label_Item" Content="Default Item" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"></Label>
        <Rectangle x:Name="Rect_hitbox" Fill="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MouseEnter="Rect_hitbox_MouseEnter" MouseLeave="Rect_hitbox_MouseLeave"></Rectangle>
    </Grid>
</UserControl>
