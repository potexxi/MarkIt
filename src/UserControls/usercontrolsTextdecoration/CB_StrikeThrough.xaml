<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_StrikeThrough"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="2" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Ellipse HorizontalAlignment="Center" Height="38" Stroke="Black" VerticalAlignment="Center" Width="30" StrokeThickness="5"/>
        <Rectangle HorizontalAlignment="Center" Height="6" Fill="Black" VerticalAlignment="Center" Width="42"/>
    </Grid>
</UserControl>
