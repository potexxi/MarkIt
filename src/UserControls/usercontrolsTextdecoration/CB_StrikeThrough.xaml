<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_StrikeThrough"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Ellipse x:Name="Ellipse_1" HorizontalAlignment="Center" Height="22" Stroke="Black" VerticalAlignment="Top" Width="24" StrokeThickness="7" Margin="0,6,0,0"/>
        <Ellipse x:Name="Ellipse_2" HorizontalAlignment="Center" Height="23" Stroke="Black" VerticalAlignment="Top" Width="24" StrokeThickness="7" Margin="0,21,0,0"/>
        <Rectangle x:Name="Rect_1" HorizontalAlignment="Center" Height="8" Fill="Black" VerticalAlignment="Center" Width="32"/>
        <Rectangle x:Name="Rect_2" HorizontalAlignment="Left" Height="6" Fill="White" VerticalAlignment="Top" Width="24" Margin="4,29,0,0"/>
        <Rectangle x:Name="Rect_3" HorizontalAlignment="Left" Height="5" Fill="White" VerticalAlignment="Top" Width="18" Margin="25,16,0,0" RenderTransformOrigin="0.5,0.5"/>
        <Rectangle x:Name="CB_Hitbox" Fill="Transparent" MouseDown="CB_Hitbox_MouseDown" MouseEnter="CB_Hitbox_MouseEnter" MouseLeave="CB_Hitbox_MouseLeave"/>

    </Grid>
</UserControl>
