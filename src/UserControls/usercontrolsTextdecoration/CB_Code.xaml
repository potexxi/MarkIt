<UserControl x:Class="MarkIt.UserControls.usercontrolsTextdecoration.CB_Code"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsTextdecoration"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Rectangle x:Name="RectBackground" StrokeThickness="4" Stroke="Black" RadiusX="5" RadiusY="5" Fill="White"/>
        <Ellipse x:Name="Ellipse_c" HorizontalAlignment="Left" Height="34" Margin="10,0,0,0" Stroke="Black" VerticalAlignment="Center" Width="38" StrokeThickness="7"/>
        <Rectangle x:Name="Rect_BGc" HorizontalAlignment="Left" Height="34" Margin="37,0,0,0" Fill="white" VerticalAlignment="Center" Width="9"/>
        <Rectangle x:Name="CB_Hitbox" Fill="Transparent" MouseDown="CB_Hitbox_MouseDown" MouseEnter="CB_Hitbox_MouseEnter" MouseLeave="CB_Hitbox_MouseLeave"/>
        
    </Grid>
</UserControl>
