<UserControl x:Class="MarkIt.UserControls.usercontrolsColor.ColorDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls.usercontrolsColor"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100">
    <Grid>
        <Rectangle Fill="White" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Stroke="Black" RadiusX="10" RadiusY="10" StrokeThickness="2"/>
    </Grid>
</UserControl>
