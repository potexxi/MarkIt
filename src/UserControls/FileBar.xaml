<UserControl x:Class="MarkIt.UserControls.FileBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:gif="http://wpfanimatedgif.codeplex.com"
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="390" d:DesignWidth="800">
    <Canvas>
        <Rectangle x:Name="RectBackground" Fill="Black" Opacity="0.5" Width="800" Height="390" PreviewMouseDown="Rectangle_PreviewMouseDown"></Rectangle>
        <Border x:Name="BorderMain" Canvas.Left="10" Canvas.Top="10" Background="#FF00006A" Width="250" Height="380" CornerRadius="15,15,15,15">
            <StackPanel>
                <ScrollViewer x:Name="ScrollViewerMain" Height="300" VerticalScrollBarVisibility="Hidden" PreviewMouseWheel="ScrollViewerMain_PreviewMouseWheel">
                    <StackPanel>
                        <Label x:Name="LabelRecent" FontSize="16" Content="Recent Files:" FontWeight="Bold" FontFamily="Leelawadee UI"></Label>
                        <StackPanel x:Name="StackPanelHistory">
                        </StackPanel>
                        <Separator/>
                        <Label x:Name="LabelLocal" FontSize="16" Content="Local Files:" FontWeight="Bold" FontFamily="Leelawadee UI"></Label>
                        <TreeView x:Name="TreeViewLocal" Background="Transparent" BorderThickness="0">
                            <!--ChatGPT-Anfang-->
                            <!--Prompt: Wie kann ich die selected color beim treeview aendern-->
                            <TreeView.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Orange"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Orange"/>
                            </TreeView.Resources>
                            <!--ChatGPT-Ende-->
                        </TreeView>
                        <Separator/>
                        <Label x:Name="LabelCloud" FontSize="16" Content="Cloud Files:" FontWeight="Bold" FontFamily="Leelawadee UI"></Label>
                        <TreeView x:Name="TreeViewCloud" Background="Transparent" BorderThickness="0">
                            <!--ChatGPT-Anfang-->
                            <!--Prompt: Wie kann ich die selected color beim treeview aendern-->
                            <TreeView.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Orange"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Orange"/>
                            </TreeView.Resources>
                            <!--ChatGPT-Ende-->
                        </TreeView>
                    </StackPanel>
                </ScrollViewer>
                <Button Cursor="Hand" x:Name="ButtonDel" Margin="0,20,0,0" Content="Delete" Click="ButtonDel_Click"></Button>
                <Button Cursor="Hand" x:Name="ButtonOpen" Content="Open" Click="ButtonOpen_Click"></Button>
            </StackPanel>
        </Border>
        <Grid Visibility="Hidden" x:Name="LoadingScreen">
            <Rectangle Fill="#FF1F4572" Opacity="0.6"></Rectangle>
            <Image Width="100" Visibility="Visible" Height="100" gif:ImageBehavior.AnimatedSource="/images/loading-animation.gif"></Image>
        </Grid>
    </Canvas>
</UserControl>
