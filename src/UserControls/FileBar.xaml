<UserControl x:Class="MarkIt.UserControls.FileBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas>
        <Rectangle Fill="Black" Opacity="0.5" Width="800" Height="450"></Rectangle>
        <Border x:Name="BorderMain" Canvas.Left="10" Background="#FF00006A" Width="250" Height="450" CornerRadius="15,15,15,15">
            <StackPanel>
                <ScrollViewer Height="370" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <StackPanel x:Name="StackPanelHistory">
                            
                        </StackPanel>
                        <TreeView x:Name="TreeViewMain">
                            
                        </TreeView>
                    </StackPanel>
                </ScrollViewer>
                <Button Margin="0,20,0,0" Content="Delete"></Button>
                <Button Content="Open"></Button>
            </StackPanel>
        </Border>
    </Canvas>
</UserControl>
