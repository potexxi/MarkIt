<UserControl x:Class="MarkIt.UserControls.FileBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="390" d:DesignWidth="800">
    <Canvas x:Name="CanvasMain">
        <Rectangle x:Name="RectBackground" Fill="Black" Opacity="0" Width="800" Height="390" PreviewMouseDown="Rectangle_PreviewMouseDown"></Rectangle>
        <Border x:Name="BorderMain" Canvas.Left="10" Canvas.Top="10" Background="#FF00006A" Width="250" Height="380" PreviewMouseDown="BorderMain_PreviewMouseDown" CornerRadius="15,15,15,15">
            <Border.RenderTransform>
                <TranslateTransform x:Name="BorderTransform" X="0"></TranslateTransform>
            </Border.RenderTransform>
            <StackPanel>
                <ScrollViewer x:Name="ScrollViewerMain" Height="270" VerticalScrollBarVisibility="Hidden" PreviewMouseWheel="ScrollViewerMain_PreviewMouseWheel">
                    <StackPanel>
                        <Label x:Name="LabelRecent" FontSize="16" Content="Recent Files:" FontWeight="Bold" FontFamily="Leelawadee UI"></Label>
                        <ScrollViewer x:Name="ScrollViewerHistory" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Visible">
                            <StackPanel x:Name="StackPanelHistory">
                            </StackPanel>
                        </ScrollViewer>
                        <Separator/>
                        <Label x:Name="LabelLocal" FontSize="16" Content="Local Files:" FontWeight="Bold" FontFamily="Leelawadee UI"></Label>
                        <TreeView x:Name="TreeViewLocal" Background="Transparent" BorderThickness="0">
                            <!--ChatGPT-Anfang-->
                            <!--Prompt: Wie kann ich die selected color beim treeview aendern-->
                            <TreeView.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Orange"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </TreeView.Resources>
                            <!--ChatGPT-Ende-->
                        </TreeView>
                        <Separator/>
                        <Label x:Name="LabelCloud" FontSize="16" Content="Cloud Files:" FontWeight="Bold" FontFamily="Leelawadee UI"></Label>
                        <TreeView x:Name="TreeViewCloud" Background="Transparent" BorderThickness="0">
                            <!--ChatGPT-Anfang-->
                            <!--Prompt: Wie kann ich die selected color beim treeview aendern-->
                            <TreeView.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Orange"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </TreeView.Resources>
                            <!--ChatGPT-Ende-->
                        </TreeView>
                    </StackPanel>
                </ScrollViewer>
                <Button Cursor="Hand" Width="200" Height="28" FontSize="14" Margin="0,5,0,0" x:Name="ButtonOpen" Content="Open" Click="ButtonOpen_Click"></Button>
                <Button Width="200" FontSize="14" Height="28" Margin="0,5,0,0" Cursor="Hand" x:Name="ButtonDel" Content="Delete" Click="ButtonDel_Click"></Button>
                <Button Width="200" FontSize="14" Height="28" Margin="0,5,0,0" Cursor="Hand" x:Name="ButtonCreate" Content="Create" Click="ButtonCreate_Click"></Button>
            </StackPanel>
        </Border>
    </Canvas>
</UserControl>
