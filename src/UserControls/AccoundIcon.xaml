<UserControl x:Class="MarkIt.UserControls.AccoundIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <Ellipse x:Name="ElliepseBody" HorizontalAlignment="Center" Height="50" Margin="0,30,0,0" Fill="Black" VerticalAlignment="Top" Width="43"/>
        <Ellipse x:Name="ElliepseHead" HorizontalAlignment="Center" Height="25" Fill="Black" VerticalAlignment="Top" Width="25" Margin="0,2,0,0"/>
        <Rectangle x:Name="RectHover" Width="50" Height="50" Fill="Transparent" MouseEnter="RectHover_MouseEnter" MouseLeave="RectHover_MouseLeave"/>
    </Grid>
</UserControl>
