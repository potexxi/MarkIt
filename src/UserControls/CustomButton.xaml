<UserControl x:Class="MarkIt.UserControls.CustomButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="100">
    <Grid>
        <Rectangle x:Name="RectButton" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Fill="LightGray" Stroke="Black" StrokeThickness="2" RadiusX="15" RadiusY="15"/>
        <Label x:Name="ButtonContent" Content="Button" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="20" FontFamily="Leelawadee UI"/>

        <Rectangle VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Fill="Transparent" MouseEnter="Rectangle_MouseEnter" MouseLeave="Rectangle_MouseLeave"/>
    </Grid>
</UserControl>
