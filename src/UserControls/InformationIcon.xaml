<UserControl x:Class="MarkIt.UserControls.InformationIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid x:Name="GridInfo">
        <Rectangle HorizontalAlignment="Center" Height="30" Margin="0,20,0,0" Fill="Black" VerticalAlignment="Top" Width="14"/>
        <Ellipse x:Name="EllispeI" HorizontalAlignment="Center" Height="14" Margin="0,2,0,0" Fill="Black" VerticalAlignment="Top" Width="14"/>

        <Rectangle HorizontalAlignment="Center" Height="50" Fill="Transparent" VerticalAlignment="Center" Width="50" MouseEnter="Rectangle_MouseEnter" MouseLeave="Rectangle_MouseLeave"/>
    </Grid>
</UserControl>
