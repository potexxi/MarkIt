<UserControl x:Class="MarkIt.UserControls.SettingsIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid >
        <Ellipse x:Name="EllipseCenter" HorizontalAlignment="Center" Height="35" Fill="Black" VerticalAlignment="Center" Width="35" StrokeThickness="10"/>
        <Rectangle x:Name="Rect1" HorizontalAlignment="Center" Height="46" Fill="Black" VerticalAlignment="Center" Width="10" RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="135"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <Rectangle x:Name="Rect2" HorizontalAlignment="Center" Height="49" Fill="Black" VerticalAlignment="Center" Width="10" RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="45"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <Rectangle x:Name="Rect3" HorizontalAlignment="Center" Height="46" Fill="Black" VerticalAlignment="Center" Width="10"/>
        <Rectangle x:Name="Rect4" HorizontalAlignment="Center" Height="10" Fill="Black" VerticalAlignment="Center" Width="46"/>
        <Ellipse x:Name="EllipseBack" HorizontalAlignment="Center" Height="19" Fill="Gray" VerticalAlignment="Center" Width="20" StrokeThickness="10"/>
        <!--Background /\ -->
            <Rectangle x:Name="RectSettingsIcon" Width="50" Height="50" Fill="Transparent" MouseEnter="RectSettingsIcon_MouseEnter" MouseLeave="RectSettingsIcon_MouseLeave" MouseDown="RectSettingsIcon_MouseDown"/>
    </Grid>
</UserControl>
