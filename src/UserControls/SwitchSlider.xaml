<UserControl x:Class="MarkIt.UserControls.SwitchSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarkIt.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="160">
    <Grid>
        <Rectangle x:Name="RectBackground" Height="30" Fill="LightGray" Width="70" RadiusX="12" RadiusY="12" Margin="80,5,7,5" />
        <Rectangle x:Name="RectDisplay" Height="30" Fill="red" Width="30" RadiusX="11" RadiusY="11" StrokeThickness="3" Margin="35,0,0,0"/>
        <Rectangle x:Name="RectBorder" Width="70" Height="30" Stroke="Black" Fill="Transparent" RadiusX="10" RadiusY="10" StrokeThickness="2" MouseLeftButtonDown="Rectangle_MouseLeftButtonDown" Margin="80,5,7,5" MouseEnter="Rectangle_MouseEnter" MouseLeave="Rectangle_MouseLeave"/>
        <Label x:Name="LabelDisplay" Content="OFF" HorizontalAlignment="Left" Margin="31,0,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="20" FontFamily="Leelawadee UI"/>
    </Grid>
</UserControl>
