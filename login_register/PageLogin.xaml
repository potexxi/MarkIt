<Page x:Class="MarkIt.login_register.PageLogin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MarkIt.login_register"
      xmlns:gif="http://wpfanimatedgif.codeplex.com"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageLogin">

    <Grid>
        <StackPanel Background="#FF1F4572" Margin="0,0,0,0">
            <Border CornerRadius="20" Background="#FF01021C" Width="400" Margin="0,15,0,0">
                <StackPanel Orientation="Vertical" Width="400" Height="360">
                    <Label Content="LOGIN" x:Name="Header" Margin="0,8,0,0" HorizontalContentAlignment="Center" Foreground="White" FontFamily="Leelawadee UI" FontSize="35" FontWeight="Bold"/>
                    <!--Email field-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="E-Mail Address" Foreground="Gray" Margin="24,15,0,0" FontFamily="Leelawadee UI"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,-3,0,0">
                        <Image x:Name="ImageEmail" Source="/images/profil-user-login.jpg" Width="45" Margin="30,0,0,0"></Image>
                        <TextBox TextChanged="TextBoxEmail_TextChanged" x:Name="TextBoxEmail" Width="290" VerticalContentAlignment="Center" MaxLength="100"></TextBox>
                    </StackPanel>
                    <!--Password field-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Password" Foreground="Gray" Margin="24,10,0,0" FontFamily="Leelawadee UI"/>
                        <Label x:Name="LabelPasswordNotCorrect" Visibility="Hidden" Content="Password not correct." Foreground="#FFFF3E3E" Margin="163,10,0,0" FontFamily="Leelawadee UI"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,-3,0,0">
                        <Image Source="/images/lock-user-login.jpg" Width="45" Margin="30,0,0,0"></Image>
                        <PasswordBox PasswordChanged="PasswordBoxPassword_PasswordChanged" x:Name="PasswordBoxPassword" Width="290" VerticalContentAlignment="Center" MaxLength="35"></PasswordBox>
                    </StackPanel>
                    <!--Remember me and forgot password-->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <CheckBox x:Name="CheckBoxRemember" Cursor="Hand" Content="Remember Me" Foreground="White" Margin="29,6,0,0" FontFamily="Leelawadee UI"/>
                        <Label Cursor="Hand" Content="Forgot Password" FontStyle="Italic" Foreground="White" Margin="140,0,0,0" FontFamily="Leelawadee UI" MouseEnter="Label_MouseEnter" MouseLeave="Label_MouseLeave" PreviewMouseDown="Label_PreviewMouseDown"/>
                    </StackPanel>
                    <!--Login button-->
                    <Button x:Name="ButtonLogin" Click="ButtonLogin_Click" Cursor="Hand" Content="LOGIN" Width="200" Height="40" FontSize="18" Margin="0,30,0,0" FontFamily="Leelawadee UI"/>
                </StackPanel>
            </Border>
            <!--Register and Guest Button-->
            <StackPanel Orientation="Horizontal" Width="335">
                <Button Margin="0,20,0,0" Content="Register instead" x:Name="ButtonRegister" Width="160" Click="ButtonRegister_Click" Cursor="Hand" FontFamily="Leelawadee UI" FontSize="14" HorizontalContentAlignment="Center" ></Button>
                <Button Margin="15,20,0,0" Content="Continue as guest" x:Name="ButtonGuest" Width="160"  Cursor="Hand" FontFamily="Leelawadee UI" FontSize="14" HorizontalContentAlignment="Center" Click="ButtonGuest_Click" ></Button>
            </StackPanel>
        </StackPanel>
        <Image x:Name="ImageLoading" Width="100" Visibility="Hidden" Height="100" gif:ImageBehavior.AnimatedSource="/images/loading-animation.gif"></Image>
    </Grid>
</Page>
